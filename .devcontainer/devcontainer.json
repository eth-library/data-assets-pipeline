{
  "name": "DAP Development",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
  "features": {
    "ghcr.io/devcontainers/features/nix:1": {
      "multiUser": true
    },
    "ghcr.io/devcontainers-community/features/direnv:1": {}
  },
  "onCreateCommand": "direnv allow . && direnv exec . true",
  "postStartCommand": "direnv exec . just dev",
  "customizations": {
    "vscode": {
      "extensions": [
        "jnoortheen.nix-ide",
        "mkhl.direnv",
        "ms-python.python",
        "charliermarsh.ruff"
      ],
      "settings": {
        "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python"
      }
    }
  },
  "remoteEnv": {
    "DIRENV_WARN_TIMEOUT": "1m"
  }
}
